{
  "name": "zulfahmi-portfolio",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "typecheck": "tsc --noEmit",
    "build:cf": "opennextjs-cloudflare build",
    "preview": "opennextjs-cloudflare build && wrangler dev",
    "deploy:dev": "opennextjs-cloudflare build && wrangler deploy --env dev",
    "deploy:prod": "opennextjs-cloudflare build && wrangler deploy --env prod",
    "lhci": "lhci autorun",
    "e2e": "playwright test",
    "e2e:install": "playwright install --with-deps chromium"
  },
  "dependencies": {
    "@opennextjs/cloudflare": "^1.19.10",
    "@react-three/fiber": "^9.6.1",
    "@shadergradient/react": "^2.4.20",
    "next": "16.2.6",
    "react": "19.2.6",
    "react-dom": "19.2.6",
    "three": "^0.184.0"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.11.3",
    "@lhci/cli": "^0.15.1",
    "@playwright/test": "^1.60.0",
    "@tailwindcss/postcss": "^4",
    "@types/node": "^25",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@types/three": "^0.184.1",
    "eslint": "^9",
    "eslint-config-next": "16.2.6",
    "tailwindcss": "^4",
    "typescript": "^6",
    "wrangler": "^4.92.0"
  },
  "overrides": {
    "@lhci/cli": {
      "lighthouse": "^13.0.2"
    }
  }
}
